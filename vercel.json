    { "source": "/blog", "destination": "/frontend/pages/blog.html" },
    { "source": "/news", "destination": "/frontend/pages/news.html" },
    { "source": "/contact", "destination": "/frontend/pages/contact.html" },
    { "source": "/track", "destination": "/frontend/pages/track.html" },
    { "source": "/customs-clearance", "destination": "/frontend/pages/customs-clearance.html" },
    { "source": "/land-transportation", "destination": "/frontend/pages/service-detail.html" },
    { "source": "/warehousing", "destination": "/frontend/pages/service-detail.html" },
